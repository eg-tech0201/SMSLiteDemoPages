@page "/surveys/results"
@using sms_lite.Services
@inject HttpClient Http
@inject IJSRuntime Js

<h1 class="page-h1">Surveys</h1>
<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb breadcrumb-mini mb-0">
        <li class="breadcrumb-item"><a href="">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Surveys</li>
    </ol>
</nav>

@if (!IsLoading && string.IsNullOrWhiteSpace(LoadError))
{
    <div class="search-shell survey-search-shell">
        <div class="search-input-row" @ref="FiltersAnchor">
            <i class="bi bi-search search-icon" aria-hidden="true"></i>
            <DxTextBox Text="@SurveySearch"
                       TextChanged="@OnSurveySearchChanged"
                       BindValueMode="BindValueMode.OnDelayedInput"
                       InputDelay="450"
                       NullText="Search by survey ID or title"
                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                       CssClass="survey-search-input" />
            <DxButton CssClass="search-filter-button survey-filter-icon-button"
                      IconCssClass="bi bi-sliders"
                      RenderStyle="ButtonRenderStyle.None"
                      Click="@ToggleFiltersMenu" />
            @if (ActiveFilterCount > 0)
            {
                <span class="survey-filter-count">Filters: @ActiveFilterCount</span>
            }
        </div>
        @if (IsFiltersMenuOpen)
        {
            <div class="filters-backdrop" @onclick="CloseFiltersMenu"></div>
            <div class="filters-pop survey-filters-pop"
                 role="dialog"
                 aria-label="Survey filters"
                 @ref="FiltersPopup">
                <div class="filters-header">
                    <div class="filters-title">Filters</div>
                    <button class="columns-close" type="button" @onclick="CloseFiltersMenu" aria-label="Close filters">x</button>
                </div>
                <div class="filters-group survey-date-group">
                    <div class="filters-subtitle">Survey Date</div>
                    <div class="survey-filter-field">
                        <DxDateEdit T="DateTime?"
                                    Date="@SurveyDateFilter"
                                    DateChanged="@OnSurveyDateFilterChanged"
                                    DisplayFormat="MM/dd/yyyy"
                                    Mask="MM/dd/yyyy"
                                    NullText="--/--/----"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </div>
                </div>
                <div class="filters-group">
                    <div class="filters-subtitle">Start / Stop Dates</div>
                    <div class="filters-row date-range-row">
                        <div class="survey-filter-field">
                            <label>Start Date</label>
                            <DxDateEdit T="DateTime?"
                                        Date="@StartDateFilter"
                                        DateChanged="@OnStartDateFilterChanged"
                                        DisplayFormat="MM/dd/yyyy"
                                        Mask="MM/dd/yyyy"
                                        NullText="--/--/----"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                        </div>
                        <div class="survey-filter-field">
                            <label>Stop Date</label>
                            <DxDateEdit T="DateTime?"
                                        Date="@StopDateFilter"
                                        DateChanged="@OnStopDateFilterChanged"
                                        DisplayFormat="MM/dd/yyyy"
                                        Mask="MM/dd/yyyy"
                                        NullText="--/--/----"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                        </div>
                    </div>
                </div>
                <div class="filters-group">
                    <div class="filters-subtitle">Modes</div>
                    <div class="filters-checks survey-filter-checks">
                        <DxCheckBox T="bool" Checked="@MailFilter" CheckedChanged="@OnMailFilterChanged">Mail</DxCheckBox>
                        <DxCheckBox T="bool" Checked="@CawiFilter" CheckedChanged="@OnCawiFilterChanged">CAWI</DxCheckBox>
                        <DxCheckBox T="bool" Checked="@CapiFilter" CheckedChanged="@OnCapiFilterChanged">CAPI</DxCheckBox>
                        <DxCheckBox T="bool" Checked="@CatiFilter" CheckedChanged="@OnCatiFilterChanged">CATI</DxCheckBox>
                    </div>
                </div>
                <div class="filters-group">
                    <div class="filters-subtitle">Status</div>
                    <div class="filters-checks survey-filter-checks">
                        <DxCheckBox T="bool" Checked="@HqReviewFilter" CheckedChanged="@OnHqReviewFilterChanged">In HQ Review</DxCheckBox>
                    </div>
                </div>
                <div class="filters-actions">
                    <button class="button-lite grid-action-button" type="button" @onclick="ClearServerFiltersAsync">Clear Filters</button>
                    <button class="button-primary" type="button" @onclick="CloseFiltersMenu">Done</button>
                </div>
            </div>
        }
    </div>
}

<div class="table-wrap dx-grid-wrap">
    @if (IsLoading)
    {
        <LoadingSwirl Text="Loading survey results" />
    }
    else if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="grid-error">@LoadError</div>
    }
    else
    {
        <div class="survey-grid-actions">
            <button class="button-lite grid-action-button" type="button" @onclick="ShowColumnChooserAsync">Customize Columns</button>
            <button class="button-lite grid-action-button" type="button" @onclick="SaveGridViewAsync">Save View</button>
            <button class="button-lite grid-action-button" type="button" @onclick="ResetGridViewAsync">Reset View</button>
            <div class="survey-grid-hint">@ResultsSummary</div>
        </div>
        <div class="survey-grid-scroll">
            @if (IsGridInteractionLoading)
            {
                <div class="survey-grid-loading-overlay">
                    <LoadingSwirl Text="Loading survey results" />
                </div>
            }
            <DxGrid @ref="SurveyGrid"
                    Data="@Rows"
                    CssClass="survey-dx-grid"
                    PageSize="@GridPageSize"
                    PagerVisible="false"
                    PageSizeSelectorVisible="false"
                    PageSizeSelectorItems="@PageSizeOptions"
                    ShowSearchBox="false"
                    ShowFilterRow="false"
                    FilterMenuButtonDisplayMode="GridFilterMenuButtonDisplayMode.Always"
                    ShowGroupPanel="true"
                    AllowGroup="true"
                    AllowSort="true"
                    AllowColumnReorder="true"
                    SelectionMode="GridSelectionMode.Multiple"
                    SelectAllCheckboxMode="GridSelectAllCheckboxMode.Page"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                    TextWrapEnabled="false">
                <Columns>
                    <DxGridSelectionColumn Width="48px" />
                    @foreach (var column in SurveyColumns)
                    {
                        <DxGridDataColumn FieldName="@column.FieldName"
                                          Caption="@column.Caption"
                                          DisplayFormat="@ResolveDisplayFormat(column)"
                                          MinWidth="@column.MinWidth"
                                          Visible="@column.VisibleByDefault">
                            <CellDisplayTemplate>
                                @{
                                    var row = (SurveyGridRow)context.DataItem;
                                }

                                @if (column.FieldName == nameof(SurveyGridRow.SurveyId))
                                {
                                    <a class="table-link" href="@BuildDetailHref(row)">@FormatCellValue(row, column.FieldName)</a>
                                }
                                else
                                {
                                    @FormatCellValue(row, column.FieldName)
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    }
                </Columns>
            </DxGrid>
        </div>
        <div class="survey-server-pager" aria-label="Survey result pages">
            <button class="button-lite grid-action-button" type="button" disabled="@IsFirstPage" @onclick="PreviousPageAsync">Previous</button>
            <span>@PageSummary</span>
            <button class="button-lite grid-action-button" type="button" disabled="@IsLastPage" @onclick="NextPageAsync">Next</button>
            <label>
                Rows
                <select class="survey-page-size-select" value="@GridPageSize" @onchange="OnGridPageSizeChanged">
                    @foreach (var pageSize in PageSizeOptions)
                    {
                        <option value="@pageSize">@pageSize</option>
                    }
                </select>
            </label>
        </div>
    }
</div>

@code {
