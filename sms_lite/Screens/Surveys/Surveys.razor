@page "/surveys/results"
@using sms_lite.Services
@inject HttpClient Http
@inject IJSRuntime Js

<h1 class="page-h1">Surveys</h1>
<nav aria-label="breadcrumb" class="mb-2">
    <ol class="breadcrumb breadcrumb-mini mb-0">
        <li class="breadcrumb-item"><a href="">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Surveys</li>
    </ol>
</nav>

<div class="surveys-toolbar">
    <div class="toolbar-left">
        <div class="search-shell">
            <div class="search-input-row">
                <button class="search-icon-button" type="button" title="Search">
                    <span class="bi bi-search" aria-hidden="true"></span>
                </button>
                <input class="survey-search search-input"
                       placeholder="Search survey results"
                       @bind="GridSearchText"
                       @bind:event="oninput" />
                <button class="search-filter-button" type="button" @onclick="ClearGridFiltersAsync" title="Clear filters">
                    <span class="bi bi-sliders" aria-hidden="true"></span>
                    <span class="filter-label">Filters</span>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="table-wrap dx-grid-wrap">
    @if (IsLoading)
    {
        <div class="grid-loading">
            <div class="app-loading-spiral" aria-hidden="true">
                <span></span>
            </div>
            <span>Loading survey results...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(LoadError))
    {
        <div class="grid-error">@LoadError</div>
    }
    else
    {
        <div class="survey-grid-actions">
            <div class="survey-grid-hint">Drag a column header left or right to reorder columns.</div>
            <button class="button-lite grid-action-button" type="button" @onclick="ShowColumnChooserAsync">Customize Columns</button>
            <button class="button-lite grid-action-button" type="button" @onclick="SaveGridViewAsync">Save View</button>
            <button class="button-lite grid-action-button" type="button" @onclick="ResetGridViewAsync">Reset View</button>
        </div>
        <div class="survey-grid-scroll">
        <DxGrid @ref="SurveyGrid"
                Data="@Rows"
                CssClass="survey-dx-grid"
                PageSize="20"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="@PageSizeOptions"
                SearchText="@GridSearchText"
                ShowSearchBox="false"
                ShowFilterRow="false"
                FilterMenuButtonDisplayMode="GridFilterMenuButtonDisplayMode.Always"
                ShowGroupPanel="false"
                AllowGroup="false"
                AllowSort="true"
                AllowColumnReorder="true"
                SelectionMode="GridSelectionMode.Multiple"
                SelectAllCheckboxMode="GridSelectAllCheckboxMode.Page"
                VirtualScrollingEnabled="true"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                TextWrapEnabled="false"
                LayoutAutoLoading="OnGridLayoutAutoLoading"
                LayoutAutoSaving="OnGridLayoutAutoSaving">
            <Columns>
                <DxGridSelectionColumn Width="48px" />
                @foreach (var column in SurveyColumns)
                {
                    <DxGridDataColumn FieldName="@column.FieldName"
                                      Caption="@column.Caption"
                                      DisplayFormat="@column.DisplayFormat"
                                      MinWidth="@column.MinWidth" />
                }
            </Columns>
        </DxGrid>
        </div>
    }
</div>

