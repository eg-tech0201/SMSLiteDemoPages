    protected override async Task OnInitializedAsync()
    {
        try
        {
            Rows = await Http.GetFromJsonAsync<List<SurveyGridRow>>("api/survey-instances") ?? [];
        }
        catch (Exception ex)
        {
            LoadError = $"Survey results could not be loaded from the server endpoint. {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ShowColumnChooserAsync()
    {
        if (SurveyGrid is not null)
        {
            SurveyGrid.ShowColumnChooser();
        }
    }

    private async Task ClearGridFiltersAsync()
    {
        if (SurveyGrid is not null)
        {
            SurveyGrid.ClearFilter();
        }
        GridSearchText = "";
        await SaveGridViewAsync();
    }

    private async Task SaveGridViewAsync()
    {
        if (SurveyGrid is null)
            return;

        var layout = SurveyGrid.SaveLayout();
        await Js.InvokeVoidAsync("smsSaveJson", SurveyGridLayoutStorageKey, layout);
    }

    private async Task ResetGridViewAsync()
    {
        await Js.InvokeVoidAsync("smsRemoveStorage", SurveyGridLayoutStorageKey);
        if (SurveyGrid is not null)
        {
            SurveyGrid.LoadLayout(new GridPersistentLayout());
        }
        GridSearchText = "";
    }

    private async Task OnGridLayoutAutoLoading(GridPersistentLayoutEventArgs e)
    {
        var layout = await Js.InvokeAsync<GridPersistentLayout?>("smsLoadJson", SurveyGridLayoutStorageKey);
        if (layout is not null)
        {
            e.Layout = layout;
        }
    }

    private async Task OnGridLayoutAutoSaving(GridPersistentLayoutEventArgs e)
    {
        await Js.InvokeVoidAsync("smsSaveJson", SurveyGridLayoutStorageKey, e.Layout);
    }

    private sealed record GridColumnSpec(string FieldName, string Caption, int MinWidth, string? DisplayFormat = null);
