@page "/surveys/details"
@page "/surveys/details/{SurveyId:int?}"
@inject HttpClient Http
@inject ILogger<SurveyDetails> Logger

<PageTitle>@(Detail?.Title ?? "Survey Details")</PageTitle>

@if (IsLoading)
{
    <LoadingSwirl Text="Loading survey details" />
}
else if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-warning">@ErrorMessage</div>
}
else if (Detail is null)
{
    <div class="alert alert-warning">No survey detail found for the selected instance.</div>
}
else
{
    <section class="detail-identity mb-2">
        <div class="detail-identity-main">
            <h1 class="detail-identity-title">@FormatValue(Detail.Title)</h1>
            <div class="detail-identity-subtitle">@FormatValue(Detail.SubTitle)</div>
        </div>
        <div class="detail-identity-meta">
            <div class="identity-line">
                <span class="identity-key">Survey ID:</span>
                <span class="identity-data">@FormatValue(Detail.SurveyId)</span>
            </div>
            <div class="identity-line">
                <span class="identity-key">Reference Date:</span>
                <span class="identity-data">@Detail.ReferenceDate.ToString("MM/dd/yyyy")</span>
            </div>
        </div>
    </section>

    <div class="details-top-layout mb-4">
        <div class="card overview-card">
            <div class="card-body top-card-body">
                <div class="count-stack-wrap overview-stack-wrap">
                    <div class="metric-label">Total Count: @Detail.TotalSample</div>
                    <div class="count-stack">
                        <span class="count-stack-received" style="width:@($"{ReceivedPercent:0.##}%")"></span>
                        <span class="count-stack-deleted" style="width:@($"{NotReceivedPercent:0.##}%")"></span>
                    </div>
                    <div class="count-stack-meta">
                        <span class="count-stack-received-text">Received: @Detail.TotalReceived (@ReceivedPercent.ToString("0.0")%)</span>
                        <span class="count-stack-deleted-text">Not received: @Detail.TotalDeleted (@NotReceivedPercent.ToString("0.0")%)</span>
                    </div>
                </div>

                <div class="survey-overview-grid compact-overview">
                    <div class="survey-overview-item"><span class="overview-label">Sample ID</span><span class="overview-value">@FormatValue(Detail.SampleId)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">Sample Name</span><span class="overview-value">@FormatValue(Detail.SampleName)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">Survey Frequency</span><span class="overview-value">@FormatValue(Detail.SurveyFrequency)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">Project Code</span><span class="overview-value">@FormatValue(Detail.ProjectCode)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">OMB Docket</span><span class="overview-value">@FormatValue(Detail.OmbNumber)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">OMB Expiration</span><span class="overview-value">@FormatDate(Detail.OmbExpiration)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">ELMO Survey ID</span><span class="overview-value">@FormatValue(Detail.ElmoSurveyId)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">ELMO Period ID</span><span class="overview-value">@FormatValue(Detail.ElmoPeriodId)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">ELMO Month</span><span class="overview-value">@FormatValue(Detail.ElmoMonth)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">Marked Version</span><span class="overview-value">@FormatValue(Detail.MarkedVersion)</span></div>
                    <div class="survey-overview-item"><span class="overview-label">Base Month</span><span class="overview-value">@FormatValue(Detail.BaseMonth)</span></div>

                    <div class="survey-overview-item survey-overview-date-range">
                        <span class="overview-label">Date Range</span>
                        <div class="date-range-table-wrap">
                            <table class="date-range-table">
                                <thead>
                                    <tr><th>Mode</th><th>Start Date</th><th>Stop Date</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Mail</td><td>@FormatDate(Detail.MailStartDate)</td><td>@FormatDate(Detail.MailStopDate)</td></tr>
                                    <tr><td>CAWI</td><td>@FormatDate(Detail.CawiStartDate)</td><td>@FormatDate(Detail.CawiStopDate)</td></tr>
                                    <tr><td>CAPI</td><td>@FormatDate(Detail.CapiStartDate)</td><td>@FormatDate(Detail.CapiStopDate)</td></tr>
                                    <tr><td>CATI</td><td>@FormatDate(Detail.CatiStartDate)</td><td>@FormatDate(Detail.CatiStopDate)</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card chart-panel-card">
            <div class="card-body top-card-body">
                <div class="count-chart-card">
                    <div class="count-chart-title">Data Collection Status</div>
                    <div class="devexpress-pie-chart">
                        <DxPieChart Data="@DataCollectionStatusPieItems"
                                    InnerDiameter="0.5"
                                    Diameter="0.62"
                                    MinDiameter="0.42"
                                    LabelOverlap="PieChartLabelOverlap.Shift">
                            <DxChartLegend Position="RelativePosition.Outside"
                                           VerticalAlignment="VerticalEdge.Bottom"
                                           HorizontalAlignment="HorizontalAlignment.Center"
                                           Orientation="Orientation.Horizontal" />
                            <DxPieChartSeries ArgumentField="@((PieSlice item) => item.DisplayText)"
                                              ValueField="@((PieSlice item) => item.Count)">
                                <DxChartSeriesLabel Visible="true"
                                                    Position="RelativePosition.Outside"
                                                    RadialOffset="12"
                                                    BackgroundColor="#ffffff"
                                                    FormatPattern="{argument}">
                                    <DxChartSeriesLabelBorder Visible="true"
                                                              Color="#d6dde4"
                                                              Width="1" />
                                    <DxChartSeriesLabelConnector Visible="true" Width="1" />
                                </DxChartSeriesLabel>
                            </DxPieChartSeries>
                            <DxChartTooltip Enabled="true" />
                        </DxPieChart>
                        <div class="devexpress-pie-total">Total: @Detail.TotalSample</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card chart-panel-card">
            <div class="card-body top-card-body">
                <div class="count-chart-card">
                    <div class="count-chart-title">Reports Received by Mode</div>
                    <div class="count-chart-visual">
                        <div class="response-pie response-pie-sm" style="background:@BuildCountPie(ReportsReceivedByModeChartItems);">
                            <div class="response-pie-center response-pie-center-sm">
                                <div class="response-pie-label">Total</div>
                                <div class="response-pie-value">@Detail.TotalReceived</div>
                            </div>
                        </div>
                        <div class="response-legend response-legend-wide">
                            @foreach (var item in ReportsReceivedByModeChartItems)
                            {
                                <div class="legend-item">
                                    <span class="legend-swatch" style="background:@item.Color"></span>
                                    <span class="legend-label">@item.Label</span>
                                    <span class="legend-value">@($"{item.Count} ({GetChartPercent(item.Count, ReportsReceivedByModeChartItems)})")</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int? SurveyId { get; set; }
    [SupplyParameterFromQuery(Name = "surveyId")] public int? SurveyIdQuery { get; set; }
    [SupplyParameterFromQuery(Name = "sampleId")] public string? SampleId { get; set; }
    [SupplyParameterFromQuery(Name = "referenceDate")] public string? ReferenceDate { get; set; }

    private SurveyInstanceDetailResponse? Detail { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }

    private static readonly string[] ChartPalette =
    [
        "#2f8f5b",
        "#d35d5d",
        "#f0b35e",
        "#5b83c5",
        "#8e6ccf",
        "#5f6b73"
    ];

    private List<CountSlice> DataCollectionStatusChartItems => Detail is null
        ? []
        :
        [
            new("1", "Complete", Detail.CompleteCount, ChartPalette[0]),
            new("2", "Refusal", Detail.RefusalCount, ChartPalette[1]),
            new("3", "Inaccessible", Detail.InaccessibleCount, ChartPalette[2]),
            new("Other", "Other Complete", Detail.OtherCompleteCount, ChartPalette[3]),
            new("900+", "Office Hold", Detail.OfficeHoldCount, ChartPalette[4]),
            new("Active", "Active & Not Checked-In", Detail.ActiveNotCheckedInCount, ChartPalette[5])
        ];

    private List<PieSlice> DataCollectionStatusPieItems => Detail is null
        ? []
        : DataCollectionStatusChartItems
            .Select(item => new PieSlice(
                $"{item.Label}: {item.Count} ({GetPercent(item.Count, Detail.TotalSample):0.0}%)",
                item.Count))
            .ToList();

    private List<CountSlice> ReportsReceivedByModeChartItems => Detail is null
        ? []
        :
        [
            new("Mail", "Mail", Detail.MailReceivedCount, ChartPalette[0]),
            new("CAWI", "CAWI", Detail.CawiReceivedCount, ChartPalette[1]),
            new("CAPI", "CAPI", Detail.CapiReceivedCount, ChartPalette[2]),
            new("READI", "READI", Detail.ReadiReceivedCount, ChartPalette[3]),
            new("Other", "Other", Detail.OtherModeReceivedCount, ChartPalette[4])
        ];

    private double ReceivedPercent => GetPercent(Detail?.TotalReceived ?? 0, Detail?.TotalSample ?? 0);
    private double NotReceivedPercent => GetPercent(Detail?.TotalDeleted ?? 0, Detail?.TotalSample ?? 0);

    protected override async Task OnParametersSetAsync()
    {
        Detail = null;
        ErrorMessage = null;

        var surveyId = SurveyIdQuery ?? SurveyId;
        if (!surveyId.HasValue ||
            string.IsNullOrWhiteSpace(SampleId) ||
            !DateTime.TryParse(ReferenceDate, out var referenceDate))
        {
            ErrorMessage = "Select Survey ID, Survey Date, and Sample ID from Survey Results.";
            return;
        }

        IsLoading = true;
        try
        {
            var url = $"api/survey-instances/detail?referenceDate={referenceDate:yyyy-MM-dd}&surveyId={surveyId.Value}&sampleId={Uri.EscapeDataString(SampleId)}";
            Detail = await Http.GetFromJsonAsync<SurveyInstanceDetailResponse>(url);
            if (Detail is null)
                ErrorMessage = "No survey detail found for the selected instance.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unable to load survey {SurveyId}, date {ReferenceDate}, sample {SampleId}.", surveyId, referenceDate, SampleId);
            ErrorMessage = "Unable to load survey details.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private static string FormatDate(DateTime? value)
        => value.HasValue ? value.Value.ToString("MM/dd/yyyy") : DisplayValue.Missing;

    private static string FormatValue(object? value)
        => DisplayValue.Text(value);

    private static double GetPercent(int count, int total)
        => total <= 0 ? 0 : count * 100d / total;

    private static string GetChartPercent(int count, IReadOnlyCollection<CountSlice> items)
        => $"{GetPercent(count, items.Sum(item => item.Count)):0.0}%";

    private static string BuildCountPie(IReadOnlyList<CountSlice> items)
    {
        var total = items.Sum(item => Math.Max(0, item.Count));
        if (total <= 0)
            return "conic-gradient(#e5e7eb 0 100%)";

        var current = 0d;
        var segments = new List<string>();
        foreach (var item in items.Where(item => item.Count > 0))
        {
            var next = current + item.Count * 100d / total;
            segments.Add($"{item.Color} {current:0.###}% {next:0.###}%");
            current = next;
        }

        return $"conic-gradient({string.Join(", ", segments)})";
    }

    private sealed record CountSlice(string Code, string Label, int Count, string Color);
    private sealed record PieSlice(string DisplayText, int Count);
}
