<div class="@CssClass" role="status" aria-live="polite">
    <div class="app-loading-spiral" aria-hidden="true">
        <span></span>
    </div>
    <div class="app-loading-text">@Text</div>
</div>

@code {
    [Parameter] public string Text { get; set; } = "Loading";
    [Parameter] public bool FullPage { get; set; }

    private string CssClass => FullPage ? "app-loading-shell loading-swirl" : "loading-swirl";
}
