{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SurveyReviewClient": {
    "BaseUrl": "https://surveyreview.nass.usda.gov/",
    "TrainingBaseUrl": "https://capitrainingbeta.nass.usda.gov/",
    "SKeyInstancePathTemplate": "services/getskeyInstance/{surveyId}/{surveyDate}",
    "InstanceOutputPathTemplate": "services/getinstanceoutput/{skey}/{publishedState}/{outputType}",
    "DownstreamTimeoutSeconds": 5,
    "CircuitBreakerFailureThreshold": 3,
    "CircuitBreakerBreakSeconds": 30
  }
}
