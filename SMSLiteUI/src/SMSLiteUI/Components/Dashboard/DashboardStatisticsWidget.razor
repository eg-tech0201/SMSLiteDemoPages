<DashboardWidget Title="Survey Metrics" CssClass="survey-metrics-panel">
    <section class="metric-bubble-grid" aria-label="Survey statistics">
        @foreach (var tile in DashboardTiles)
        {
            <div class="@($"metric-bubble {tile.CssClass}")">
                <div class="@($"metric-bubble-label {tile.LabelSizeClass}")">@tile.Title:</div>
                <div class="metric-bubble-value">@tile.Value</div>
            </div>
        }
    </section>
</DashboardWidget>
