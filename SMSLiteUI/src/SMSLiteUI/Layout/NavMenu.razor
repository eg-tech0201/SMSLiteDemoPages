@inject NavigationManager Navigation

<header class="top-nav">
    <div class="top-nav-inner">
        <div class="top-nav-left">
            <a class="navbar-brand brand-lockup" href="">
                <img class="brand-logo" src="usda%20logo%20white%20transparent.png" alt="USDA logo" />
                <span class="brand-text">
                    <span class="brand-title">United States Department of Agriculture</span>
                    <span class="brand-subtitle">National Agricultural Statistics Service</span>
                </span>
            </a>
            <nav class="navigation-scrollable">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-speedometer2" aria-hidden="true"></span> Dashboard
                </NavLink>
                <NavLink class="nav-link" href="assignments">
                    <span class="bi bi-person-workspace" aria-hidden="true"></span> Assignments
                </NavLink>
                <div class="nav-group">
                    <NavLink class="nav-link" href="surveys">
                        <span class="bi bi-card-list" aria-hidden="true"></span> Surveys
                    </NavLink>
                    <div class="nav-dropdown" role="menu" aria-label="Surveys submenu">
                        <div class="nav-subgroup">
                            <a class="nav-subitem" href="surveys">
                                <span>Survey Search</span>
                                <span class="nav-arrow" aria-hidden="true">›</span>
                            </a>
                            <div class="nav-submenu" role="menu">
                                <a class="nav-subitem" href="surveys/details">Details</a>
                                <a class="nav-subitem" href="surveys/details/metadata">Metadata</a>
                                <a class="nav-subitem" href="surveys/details/exports">Exports</a>
                            </div>
                        </div>
                        <div class="nav-subgroup">
                            <a class="nav-subitem" href="surveys/results">
                                <span>Survey Results</span>
                                <span class="nav-arrow" aria-hidden="true">›</span>
                            </a>
                            <div class="nav-submenu" role="menu">
                                <a class="nav-subitem" href="surveys/results/opdom">OpDom Summary</a>
                                <a class="nav-subitem" href="surveys/results/dcms">DCMS Summary</a>
                                <a class="nav-subitem" href="surveys/results/exports">Bulk Exports</a>
                            </div>
                        </div>
                        <div class="nav-subgroup">
                            <a class="nav-subitem" href="surveys/admin">
                                <span>Survey Admin</span>
                                <span class="nav-arrow" aria-hidden="true">›</span>
                            </a>
                            <div class="nav-submenu" role="menu">
                                <a class="nav-subitem" href="surveys/admin/modes">Modes</a>
                                <a class="nav-subitem" href="surveys/admin/assignments">Assignments</a>
                                <a class="nav-subitem" href="surveys/admin/metadata">Metadata</a>
                            </div>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
        <div class="top-nav-right">
            <form class="global-search-form" @onsubmit="SubmitGlobalSearch" @onsubmit:preventDefault="true">
                <input class="global-search-input"
                       placeholder="Search by FIPS, POID, survey name, or survey ID"
                       @bind="GlobalSearchText"
                       @bind:event="oninput" />
                <button type="submit" class="global-search-button" title="Search">
                    <span class="bi bi-search" aria-hidden="true"></span>
                </button>
            </form>
            <button type="button" class="icon-button" title="Notifications" @onclick="ToggleNotifications">
                <span class="bi bi-bell" aria-hidden="true"></span>
                <span class="badge">4</span>
            </button>
            <span class="email">@CurrentUser.DisplayEmail</span>
            <button type="button" class="avatar" title="User menu" @onclick="ToggleUserMenu">
                <span class="bi bi-person-circle" aria-hidden="true"></span>
            </button>
        </div>
    </div>
</header>

@if (ShowNotifications)
{
    <div class="user-menu-backdrop" @onclick="CloseMenus"></div>
    <div class="notif-dropdown" @onclick:stopPropagation="true">
        <div class="notif-header">Notifications</div>
        <ul>
            <li><strong>Survey 1004</strong> — 3 responses due this week</li>
            <li><strong>Survey 1001</strong> — Enumerator update required</li>
            <li><strong>Assignments</strong> — Bulk reassignment functions are not yet connected</li>
        </ul>
    </div>
}

@if (ShowUserMenu)
{
    <div class="user-menu-backdrop" @onclick="CloseMenus"></div>
    <div class="user-menu" @onclick:stopPropagation="true">
        <div class="user-menu-header">
            <span>Welcome, @CurrentUser.DisplayEmail</span>
            <strong>@(CurrentUser.DisplayName ?? "User Menu")</strong>
        </div>
        <div class="user-menu-section-title">Account</div>
        <div class="user-menu-item">Profile</div>
        <div class="user-menu-item">Settings</div>
        <div class="user-menu-item">Sign out</div>
    </div>
}
